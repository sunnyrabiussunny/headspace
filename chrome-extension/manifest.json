{
  "manifest_version": 3,
  "name": "Headspace Time Tracker",
  "version": "1.0.2",
  "description": "Log time to your self-hosted Headspace from any Chrome tab",
  "permissions": ["storage", "alarms", "notifications"],
  "host_permissions": [
    "http://192.168.10.103:5151/*",
    "http://localhost:*/*",
    "http://192.168.*.*:*/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    },
    "default_title": "Headspace Time Tracker"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
